ls()
library(readr)
ghpr <- read_csv("~/Downloads/ghpr.csv")
View(ghpr)
pr_cleaned_data <- ghpr %>%
# Select required columns
select(
repo_id,
pull_created_at,
pull_merged_at,
pull_additions,
pull_deletions,
pull_changed_files,
pull_comments,
pull_review_comments,
issue_author_association
) %>%
# Convert timestamps and create derived variables
mutate(
pull_created_at = as_datetime(pull_created_at),
pull_merged_at  = as_datetime(pull_merged_at),
# Review time in days
review_time_days = as.numeric(
difftime(pull_merged_at, pull_created_at, units = "days")
),
# Collaboration activity
total_comments = replace_na(pull_comments, 0) +
replace_na(pull_review_comments, 0),
merged = !is.na(pull_merged_at)
) %>%
# Retain valid merged pull requests
filter(
merged == TRUE,
review_time_days >= 0
) %>%
# Log-transform response variable
mutate(
log_review_time = log(review_time_days + 1)
) %>%
# Create PR size factor
{
data <- .
median_files <- median(data$pull_changed_files, na.rm = TRUE)
data %>%
mutate(
pr_size = factor(
ifelse(
pull_changed_files > median_files,
"Large PR", "Small PR"
)
)
)
} %>%
# Convert author association to factor
mutate(
issue_author_association = factor(
issue_author_association,
levels = c(1, 6),
labels = c("Contributor", "Member")
)
) %>%
# Final analysis dataset
select(
repo_id,
log_review_time,
review_time_days,
pull_additions,
pull_deletions,
pull_changed_files,
total_comments,
issue_author_association,
pr_size,
pull_created_at,
pull_merged_at
) %>%
filter(!is.na(issue_author_association))
library(tidyverse)    # Data manipulation and visualization
library(lubridate)    # Date-time handling
library(car)          # Levene’s Test
library(ggplot2)      # Plots
library(ggfortify)    # Diagnostic plots
library(agricolae)    # Tukey HSD with compact letter display
pr_cleaned_data <- ghpr %>%
# Select required columns
select(
repo_id,
pull_created_at,
pull_merged_at,
