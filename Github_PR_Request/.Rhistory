total_comments,
issue_author_association,
pr_size,
pull_created_at,
pull_merged_at
) %>%
filter(!is.na(issue_author_association))
summary(pr_cleaned_data)
pr_cleaned_data %>%
summarise(
total_prs = n(),
mean_review_time_days = mean(review_time_days, na.rm = TRUE),
median_review_time_days = median(review_time_days, na.rm = TRUE),
sd_review_time_days = sd(review_time_days, na.rm = TRUE),
min_review_time_days = min(review_time_days, na.rm = TRUE),
max_review_time_days = max(review_time_days, na.rm = TRUE),
mean_additions = mean(pull_additions, na.rm = TRUE),
mean_deletions = mean(pull_deletions, na.rm = TRUE),
mean_files_changed = mean(pull_changed_files, na.rm = TRUE),
mean_total_comments = mean(total_comments, na.rm = TRUE)
)
