library(readr)
ghpr <- read_csv("~/Downloads/ghpr.csv")
View(ghpr)
View(ghpr)
glimpse(ghpr)
pr_data <- ghpr %>%
select(
pull_created_at,
pull_merged_at,
pull_additions,
pull_deletions,
pull_changed_files,
pull_comments,
pull_review_comments,
issue_author_association
) %>%
mutate(
pull_created_at = as_datetime(pull_created_at),
pull_merged_at  = as_datetime(pull_merged_at),
review_time_days = as.numeric(
difftime(pull_merged_at, pull_created_at, units = "days")
),
pull_additions     = as.numeric(pull_additions),
pull_deletions     = as.numeric(pull_deletions),
pull_changed_files = as.numeric(pull_changed_files),
total_comments =
replace_na(pull_comments, 0) +
replace_na(pull_review_comments, 0),
issue_author_association = factor(
issue_author_association,
levels = c(1, 6),
labels = c("Contributor", "Member")
),
merged = !is.na(pull_merged_at)
) %>%
filter(
!is.na(review_time_days),
review_time_days >= 0,
!is.na(issue_author_association)
) %>%
select(
pull_created_at,
pull_merged_at,
review_time_days,
pull_additions,
pull_deletions,
pull_changed_files,
total_comments,
issue_author_association,
merged
)
str(pr_data)
summary(pr_data)
table(pr_data$merged)
table(pr_data$issue_author_association)
View(pr_data)
